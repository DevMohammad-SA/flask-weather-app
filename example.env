# Weatherstack API key used in api_request.py
# Get one from: https://weatherstack.com/
ACCESS_KEY=your_weatherstack_access_key_here

# Flask secret key used for sessions/flash messages (app/__init__.py)
# Generate one e.g. with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string

# Optional: only needed if you actually use a database (currently referenced in app/__init__.py)
# Examples:
# SQLite: sqlite:///app.db
# Postgres: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///app.db
